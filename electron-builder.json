{
  "appId": "com.secnote.app",
  "productName": "secNote",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "win": {
    "target": ["nsis"],
    "icon": null
  },
  "mac": {
    "target": ["dmg"],
    "icon": null
  },
  "linux": {
    "target": ["AppImage"],
    "icon": null
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true
  }
}
